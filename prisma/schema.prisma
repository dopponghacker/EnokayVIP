generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AdminCredential {
  id           String   @id @default("admin")
  username     String   @unique
  passwordHash String
  passwordSalt String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model VipTip {
  id         String   @id @default(cuid())
  tier       String
  homeTeam   String
  awayTeam   String
  prediction String
  league     String
  time       String
  date       String
  odds       String?
  confidence String   @default("Medium")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("vip_tips")
}

model PublicMatch {
  id         String   @id @default(cuid())
  homeTeam   String
  awayTeam   String
  prediction String
  league     String
  odds       String?
  date       String
  time       String
  status     String   @default("pending")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("public_matches")
}

model BookingCode {
  id        String   @id @default(cuid())
  tier      String
  date      String
  code      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tier, date])
  @@map("booking_codes")
}
model Payment {
  id          String   @id @default(cuid())
  externalRef String   @unique
  tier        String
  amount      Float
  currency    String   @default("GHS")
  phone       String
  channel     Int
  status      String   @default("pending")
  moolreId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("payments")
}

model TierPrice {
  tier      String   @id
  amount    Float
  updatedAt DateTime @updatedAt

  @@map("tier_prices")
}
